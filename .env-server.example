# Secrets referenced from config/orchestrator.toml via env:VAR_NAME syntax.

# Web backend token (used by the client to authenticate)
WEB_TOKEN=your-secret-token

# Telegram backend (if enabled in orchestrator.toml)
TELEGRAM_BOT_TOKEN=

# Discord backend (if enabled in orchestrator.toml)
DISCORD_BOT_TOKEN=

# Orchestrator LLM (if enabled in orchestrator.toml)
OPENROUTER_API_KEY=
